/* =========================
   1024px
========================= */
@media screen and (max-width: 1024px) {

.hero-image {
    width: 645px;
}

.custom-hero__heading {
    font-size: 50px;
    line-height: 1;
    margin: 0 0 40px;
}

.custom-hero__description {
    font-size: 19px;
    line-height: 132%;
    max-width: 307px;
}

.custom-hero__button {
    padding: 11px 20px;
    margin-top: 10px;
}

.tisso-wild-grid-wrapper {
    padding-top: 40px;
}

.tisso-color-swatches button {
    width: 47%;
    height: 40px;
    font-size: 15px;
}

.tisso-option-wrapper {
    margin-bottom: 10px;
}

.tisso-select-wrapper select {
    height: 36px;
    padding: 0 10px;
    font-size: 16px;
}

#tissoModalTitle {
    margin: 0 0 5px;
    font-size: 15px;
}

#tissoAddToCartBtn {
    height: 40px;
    gap: 27px;
    font-size: 15px;
}

.custom-header__button {
    padding: 10px 24px 11px 26px;
    font-size: 16px;
}
}


/* =========================
   980px
========================= */
@media screen and (max-width: 980px) {
.hero-image {
    width: 599px;
}
}


/* =========================
   768px
========================= */
@media screen and (max-width: 768px) {

.custom-hero__heading {
    font-size: 39px;
    line-height: 1.1;
    margin: 0 0 25px;
}

.custom-hero__content {
    padding-top: 327px;
}

.hero-image {
    width: 419px;
    height: 272px;
}

.custom-hero {
    min-height: 586px;
}
}


/* =========================
   650px FIXED (IMPORTANT)
========================= */
@media screen and (max-width: 650px) {

.custom-header__button {
    padding: 13px 10px 10px 9px;
    font-size: 14px;
}

.page-width {
    padding: 0 15px;
}

/* 🔥 IMPORTANT FIX: prevent 375px overriding issue */
.custom-hero__heading {
    font-size: 34px;
    line-height: 1.2;
}

.custom-hero__description {
    font-size: 14px;
    line-height: 20px;
}

.custom-hero__button {
    padding: 10px 18px;
    font-size: 13px;
}

.tisso-wild-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
}
}


/* =========================
   375px (MOBILE LAST - FIXED)
========================= */
@media screen and (max-width: 375px) {

* {
    box-sizing: border-box;
}

.page-width {
    padding: 0 16px;
}

img {
    max-width: 100%;
    height: auto;
    display: block;
}

/* Header */
.custom-header-wrapper {
    padding: 12px 0;
    gap: 10px;
    flex-wrap: wrap;
}

.custom-header__logo {
    max-width: 90px;
}

.custom-header__announcement {
    font-size: 10px;
    line-height: 14px;
    flex: 1;
    text-align: center;
}

.custom-header__button {
    padding: 10px 14px;
    font-size: 10px;
    white-space: nowrap;
}

/* Hero */
.custom-hero__content {
    padding-top: 200px;
    text-align: center;
}

.custom-hero__heading {
    font-size: 32px;
    line-height: 1.1;
}

.custom-hero__description {
    font-size: 12px;
    line-height: 18px;
}

.custom-hero__button {
    margin-top: 20px;
    padding: 10px 20px;
    font-size: 12px;
}

.hero-image {
    position: relative;
    width: 100%;
    height: auto;
    background: none;
}

/* Grid */
.tisso-wild-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
}
}