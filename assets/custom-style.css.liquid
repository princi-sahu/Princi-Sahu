html,
body,
* {
  font-family: "Jost" !important;
}
p,a {
    font-family: "Jost" !important;
}
.page-width {
    max-width: 1440px;
    width: 100%;
    padding: 0px 50px;
    margin: 0 auto;
}
.custom-header{
    background: #F5F5F5;
    padding: 10px 0px;
}
.custom-header__logo {
    max-width: 151px;
}
.custom-header-wrapper {
    padding: 10px 0px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.custom-header__announcement {
    font-weight: 400;
    font-size: 16px;
    line-height: 13.42px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
}
.custom-header__button {
    padding: 21px 32px 21px 40px;
    background: #FFF544;
    font-weight: 400;
    font-size: 16px;
    line-height: 20.48px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
}

.custom-hero__heading {
    font-family: josh;
    font-size: 70px;
    line-height: 100%;
    font-weight: 00;
    color: #000;
    margin: 0 0 50px;
}

.custom-hero__button {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 14px 32px;
    background: #000;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 14px;
    font-weight: 500;
    margin-top: 50px;
}
.custom-hero__description {
    margin: 0;
    font-size: 20px;
    font-weight: 400;
    line-height: 140%;
    max-width: 483px;
    font-style: unset;
}
.custom-hero__button:hover{
  opacity:.85;
}
.custom-hero {
    position: relative;
    overflow: hidden;
    min-height:720px;
    background: #FFFFFF;
}
.custom-hero__bg{
    position: absolute;
    inset: 0;
    background-image: url('/cdn/shop/t/5/assets/frame-bg.svg?v=93124217167391876821781715212');
    background-repeat: no-repeat;
    background-size: cover;
    background-position: bottom center;
    z-index: 1;
    height: 390px;
    overflow: hidden;
}
.hero-image {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 100%;
    height: 338px;
    background-image: url(/cdn/shop/t/5/assets/frame-bg.svg?v=93124217167391876821781715212);
    background-repeat: no-repeat;
    background-size: cover;
    width: 800px;
}
.custom-hero__content {
    padding-top: 425px;
}
.tisso-wild-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 20px;
}
.custom-hero__bottom-text {
    background: #F5F5F5;
    padding: 10px;
    font-weight: 400;
    font-size: 16px;
    line-height: 13.42px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
}
.tisso-wild-section h2 {
    font-weight: 400;
    font-size: 36px;
    line-height: 120%;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000000;
}
.tisso-wild-section {
    padding:90px 0px 51px;
}
.tisso-hotspot-pin{
    top: 50%;
    left: 53%;
    position: absolute;
    border-radius: 50%;
    border: none;
}
.tisso-wild-item{
    position:relative;
}
  .tisso-modal{
  display:none;
  position:fixed;
  inset:0;
  z-index:999;
}

.tisso-modal.is-open{
  display:block;
}

.tisso-modal-overlay{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.4);
}
.tisso-modal-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    width: 100%;
    max-width: 331px;
    background: #FFFFFF;
    padding: 36px 20px 25px;
}

.tisso-modal-close{
  position:absolute;
  top:15px;
  right:20px;
  border:none;
  background:none;
  font-size:42px;
  cursor:pointer;
}

.tisso-modal-top {
    display: flex;
    gap: 8px;
    margin-bottom: 7px;
}
.tisso-modal-left {
    max-width: 120px;
    max-height: 140px;
    width: 100%;
    height: 100%;
}
.tisso-modal-left img{
  width:100%;
  display:block;
}
#tissoModalTitle {
    margin: 0 0 20px;
    font-weight: 300;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0px;
    vertical-align: middle;
    margin-bottom: 20px;
}
#tissoModalPrice {
    margin-bottom: 12px;
    font-family: Lustria;
    font-weight: 400;
    font-style: Regular;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0px;
}
#tissoModalDesc {
    font-family: Jost;
    font-weight: 300;
    font-style: Light;
    font-size: 14px;
    leading-trim: NONE;
    line-height: 110.00000000000001%;
    letter-spacing: -1%;
   color: #000000;

}

.tisso-option-wrapper{
  margin-bottom:20px;
}

.tisso-option-wrapper label{
  display:block;
  margin-bottom:10px;
  font-size:16px;
}

.tisso-color-swatches{
  display:flex;
}

.tisso-color-swatches button{
  width:50%;
  height:60px;
  border:1px solid #000;
  background:#fff;
  font-size:18px;
  cursor:pointer;
}

.tisso-color-swatches button.active{
  border:3px solid #000;
}

.tisso-select-wrapper select{
  width:100%;
  height:60px;
  padding:0 20px;
  border:1px solid #000;
  font-size:18px;
  background:#fff;
}

#tissoAddToCartBtn{
  width:100%;
  height:68px;
  border:none;
  background:#000;
  color:#fff;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:40px;
  font-size:18px;
  cursor:pointer;
}
.tisso-color-swatches button.active{
  background:#000;
  color:#fff;
  border:1px solid #000;
}
.tisso-wild-grid-wrapper {
    padding-top: 90px;
}
@media screen and (max-width: 1024px) {
.hero-image {
    width: 645px;
}
.custom-hero__heading {
    font-size: 50px;
    line-height: 0%;
    margin: 0 0 40px;
}
.custom-hero__description {
    font-size: 19px;
    line-height: 132%;
    max-width: 307px;
}
.custom-hero__button {
    padding: 11px 20px;
    margin-top: 10px;
}
.tisso-wild-grid-wrapper {
    padding-top: 40px;
}
.tisso-color-swatches button {
    width: 47%;
    height: 40px;
    font-size: 15px;
}
.tisso-option-wrapper {
    margin-bottom: 10px;
}
.tisso-select-wrapper select {
    width: 100%;
    height: 36px;
    padding: 0 10px;
    font-size: 16px;
}
#tissoModalTitle {
    margin: 0 0 5px;
    font-size: 15px;
}
#tissoAddToCartBtn {
    width: 97%;
    height: 40px;
    gap: 27px;
    font-size: 15px;
}
.custom-header__button {
    padding: 10px 24px 11px 26px;
    font-weight: 400;
    font-size: 16px;
}
}
@media screen and (max-width: 980px) {

.hero-image {
    width: 599px;
}
}
@media screen and (max-width: 768px) {

.custom-hero__heading {
    font-size: 39px;
    line-height: 0%;
    margin: 0 0 25px;
}
.custom-hero__content {
    padding-top: 327px;
}
.hero-image {
    width: 419px;
    height: 272px;
}
.custom-hero {
    position: relative;
    overflow: hidden;
    min-height: 586px;
    background: #fff;
}
}
@media screen and (max-width: 650px) {

.custom-header__button {
    padding: 13px 10px 10px 9px;
    font-weight: 400;
    font-size: 14px;
}
}
@media screen and (max-width: 375px) {

  *{
    box-sizing:border-box;
  }

  .page-width{
    padding:0 16px;
  }

  img{
    max-width:100%;
    height:auto;
    display:block;
  }

  /* Header */

  .custom-header-wrapper{
    padding:12px 0;
    gap:10px;
    flex-wrap:wrap;
  }

  .custom-header__logo{
    max-width:90px;
  }

  .custom-header__announcement{
    font-size:10px;
    line-height:14px;
    flex:1;
    text-align:center;
  }

  .custom-header__button{
    padding:10px 14px;
    font-size:10px;
    white-space:nowrap;
  }

  /* Hero */

  .custom-hero{
    min-height:auto;
    overflow:hidden;
  }

  .custom-hero__bg{
    height:180px;
    background-size:cover;
    background-position:center;
  }

  .custom-hero__content{
    padding-top:200px;
    text-align:center;
  }

  .custom-hero__heading{
    font-size:32px;
    line-height:1.1;
    margin-bottom:16px;
  }

  .custom-hero__description{
    font-size:12px;
    line-height:18px;
    max-width:100%;
    margin:auto;
  }

  .custom-hero__button{
    margin-top:20px;
    padding:10px 20px;
    font-size:12px;
  }

  .hero-image{
    position:relative;
    width:100%;
    height:auto;
    right:auto;
    bottom:auto;
    margin-top:20px;
    background:none;
  }

  .custom-hero__bottom-text{
    font-size:10px;
    line-height:14px;
    padding:8px;
  }

  /* Tisso Section */

  .tisso-wild-section{
    padding:40px 0 24px;
  }

  .tisso-wild-section h2{
    font-size:28px;
    text-align:center;
    margin-bottom:20px;
  }

  .tisso-wild-grid-wrapper{
    padding-top:20px;
  }

  .tisso-wild-grid{
    grid-template-columns:repeat(2,1fr);
    gap:4px;
  }

  .tisso-wild-item{
    overflow:hidden;
  }

  .tisso-wild-item img{
    width:100%;
    display:block;
  }

  .tisso-hotspot-pin{
    width:28px;
    height:28px;
    font-size:16px;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    padding:0;
  }

  /* Modal */

  .tisso-modal-content{
    width:calc(100% - 24px);
    max-width:none;
    padding:20px 15px;
  }

  .tisso-modal-top{
    gap:10px;
  }

  .tisso-modal-left{
    max-width:100px;
  }

  #tissoModalTitle{
    font-size:14px;
    margin-bottom:8px;
  }

  #tissoModalPrice{
    font-size:14px;
    margin-bottom:8px;
  }

  #tissoModalDesc{
    font-size:12px;
    line-height:1.4;
  }

  .tisso-color-swatches button{
    height:48px;
    font-size:14px;
  }

  .tisso-select-wrapper select{
    height:48px;
    font-size:14px;
  }

  #tissoAddToCartBtn{
    height:54px;
    font-size:14px;
    gap:20px;
  }

  .tisso-modal-close{
    font-size:28px;
    top:8px;
    right:12px;
  }
}