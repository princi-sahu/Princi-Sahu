html,
body,
* {
  font-family: "Jost" !important;
}
p,a {
    font-family: "Jost" !important;
}
.page-width {
    max-width: 1440px;
    width: 100%;
    padding: 0px 50px;
    margin: 0 auto;
}
.custom-header{
    background: #F5F5F5;
    padding: 10px 0px;
}
.custom-header__logo {
    max-width: 151px;
}
.custom-header-wrapper {
    padding: 10px 0px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.custom-header__announcement {
    font-weight: 400;
    font-size: 16px;
    line-height: 13.42px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
}
.custom-header__button {
    padding: 21px 32px 21px 40px;
    background: #FFF544;
    font-weight: 400;
    font-size: 16px;
    line-height: 20.48px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
}

.custom-hero__heading {
    font-family: josh;
    font-size: 70px;
    line-height: 100%;
    font-weight: 00;
    color: #000;
    margin: 0 0 50px;
}

.custom-hero__button{
  display:inline-flex;
  align-items:center;
  gap:16px;
  padding:14px 32px;
  background:#000;
  color:#fff;
  text-decoration:none;
  text-transform:uppercase;
  font-size:14px;
  font-weight:500;
}
.custom-hero__description {
    margin: 0;
    font-size: 20px;
    font-weight: 400;
    line-height: 140%;
    max-width: 483px;
    font-style: unset;
}
.custom-hero__button:hover{
  opacity:.85;
}
.custom-hero {
    position: relative;
    overflow: hidden;
    background: #FFFFFF;
}
.custom-hero__bg{
    position: absolute;
    inset: 0;
    background-image: url('/cdn/shop/t/5/assets/frame-bg.svg?v=93124217167391876821781715212');
    background-repeat: no-repeat;
    background-size: cover;
    background-position: bottom center;
    z-index: 1;
    height: 390px;
    overflow: hidden;
}
.hero-image {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 100%;
    height: 356px;
    background-image: url(/cdn/shop/t/5/assets/frame-bg.svg?v=93124217167391876821781715212);
    background-repeat: no-repeat;
    background-size: cover;
    width: 800px;
}
.custom-hero__content {
    padding-top: 425px;
}
.tisso-wild-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
}