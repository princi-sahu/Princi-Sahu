<div class="tisso-wild-grid-wrapper">
  <div class="page-width">
    {% if section.settings.heading != blank %}
  <h2 class="section-heading">
    {{ section.settings.heading }}
  </h2>
{% endif %}
    <div class="tisso-wild-grid">
  {% for block in section.blocks %}
   
    {% assign product = block.settings.product %}

    {% if product != blank %}
      <div class="tisso-wild-item" {{ block.shopify_attributes }}>

        {% if product.featured_image %}
          {{
            product.featured_image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              alt: product.title
          }}
        {% endif %}

       <button
      type="button"
     class="tisso-hotspot-pin"
    style="top:{{ block.settings.pin_top }}%; left:{{ block.settings.pin_left }}%;"
    data-title="{{ product.title }}"
    data-price="{{ product.price | money }}"
    data-desc="{{ product.description | strip_html | truncate: 120 }}"
    data-img="{{ product.featured_image | image_url: width: 500 }}"
    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
    >
    +
   </button>

      </div>
    {% endif %}

  {% endfor %}
</div>
</div>
</div>
<!-- Modal -->

<div id="tissoQuickViewModal" class="tisso-modal">

  <div class="tisso-modal-overlay"></div>
 <div class="tisso-model-content-wrapper">
  <div class="tisso-modal-content">

    <div class="tisso-modal-top">

      <div class="tisso-modal-left">
        <img id="tissoModalImg" src="" alt="">
      </div>

      <div class="tisso-modal-right">

        <h3 id="tissoModalTitle"></h3>

        <div id="tissoModalPrice"></div>

        <p id="tissoModalDesc"></p>

      </div>
  
       <button class="tisso-modal-close">&times;</button>
</div>

    <div class="tisso-option-wrapper">
      <label>Color</label>

      <div class="tisso-color-swatches">
        <button type="button" class="active">White</button>
        <button type="button">Black</button>
      </div>
    </div>

    <div class="tisso-option-wrapper">
      <label>Size</label>

      <div class="tisso-select-wrapper">
        <select>
          <option selected disabled>Choose your size</option>
          <option>Small</option>
          <option>Medium</option>
          <option>Large</option>
        </select>
      </div>
    </div>

    <button id="tissoAddToCartBtn">
      <span>ADD TO CART</span>
      <span>→</span>
    </button>
  
  </div>
     </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const modal = document.getElementById("tissoQuickViewModal");

  const modalImg = document.getElementById("tissoModalImg");
  const modalTitle = document.getElementById("tissoModalTitle");
  const modalPrice = document.getElementById("tissoModalPrice");
  const modalDesc = document.getElementById("tissoModalDesc");

  /* Open Modal */
  document.querySelectorAll(".tisso-hotspot-pin").forEach(pin => {

    pin.addEventListener("click", () => {

      modalImg.src = pin.dataset.img;
      modalTitle.textContent = pin.dataset.title;
      modalPrice.textContent = pin.dataset.price;
      modalDesc.textContent = pin.dataset.desc;

      modal.classList.add("is-open");

    });

  });

  /* Close Modal */
  document.querySelector(".tisso-modal-close").addEventListener("click", () => {
    modal.classList.remove("is-open");
  });

  document.querySelector(".tisso-modal-overlay").addEventListener("click", () => {
    modal.classList.remove("is-open");
  });

  /* Color Toggle */
  const colorButtons = document.querySelectorAll(".tisso-color-swatches button");

  colorButtons.forEach(button => {

    button.addEventListener("click", () => {

      colorButtons.forEach(btn => {
        btn.classList.remove("active");
      });

      button.classList.add("active");

    });

  });

});
</script>


{% schema %}
{
  "name": "Tisso Wild Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vision in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Product Item",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "range",
          "id": "pin_top",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "label": "Pin Top"
        },
        {
          "type": "range",
          "id": "pin_left",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "label": "Pin Left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}
