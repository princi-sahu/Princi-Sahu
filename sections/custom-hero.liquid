<div class="custom-hero">
  <div class="page-width">

    {% if section.settings.bg_image != blank %}
      <div class="custom-hero__bg">
        {{
          section.settings.bg_image
          | image_url: width: 2000
          | image_tag:
            class: 'custom-hero__bg-image',
            loading: 'lazy',
            alt: 'Background Image'
        }}
      </div>
    {% endif %}

    <div class="custom-hero__content">

      {% if section.settings.heading != blank %}
        <h1 class="custom-hero__heading">
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="custom-hero__description">
          {{ section.settings.description }}
        </p>
      {% endif %}

      {% if section.settings.button_text != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="custom-hero__button">
          <span>{{ section.settings.button_text }}</span>
          <span>&rarr;</span>
        </a>
      {% endif %}

    </div>

    {% if section.settings.bottom_text != blank %}
      <p class="custom-hero__bottom-text">
        {{ section.settings.bottom_text }}
      </p>
    {% endif %}

    {% if section.settings.hero_image != blank %}
      <div class="hero-image">
        {{
          section.settings.hero_image
          | image_url: width: 1200
          | image_tag:
            class: 'hero-image__img',
            loading: 'lazy',
            alt: section.settings.heading
        }}
      </div>
    {% endif %}

  </div>
</div>

<style>
.custom-hero{
  position:relative;
  overflow:hidden;
  background:#F5F5F5;
}

.custom-hero .page-width{
  position:relative;
  min-height:760px;
  display:flex;
  align-items:center;
}

.custom-hero__bg{
  position:absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
  z-index:1;
}

.custom-hero__bg-image{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

.custom-hero__content{
  position:relative;
  z-index:2;
  max-width:550px;
}

.custom-hero__heading{
  font-size:96px;
  line-height:1;
  font-weight:700;
  margin:0 0 24px;
}

.custom-hero__description{
  font-size:18px;
  line-height:1.6;
  max-width:450px;
  margin:0 0 32px;
}

.custom-hero__button{
  display:inline-flex;
  align-items:center;
  gap:15px;
  background:#000;
  color:#fff;
  text-decoration:none;
  padding:16px 28px;
  font-size:14px;
  text-transform:uppercase;
}

.hero-image{
  position:absolute;
  right:0;
  top:50%;
  transform:translateY(-50%);
  z-index:2;
  max-width:700px;
}

.hero-image__img{
  width:100%;
  height:auto;
  display:block;
}

.custom-hero__bottom-text{
  position:absolute;
  bottom:20px;
  left:50%;
  transform:translateX(-50%);
  z-index:2;
  width:100%;
  text-align:center;
  font-size:12px;
  text-transform:uppercase;
  letter-spacing:1px;
}

@media screen and (max-width:768px){

  .custom-hero .page-width{
    min-height:600px;
    padding-top:80px;
    padding-bottom:80px;
  }

  .custom-hero__heading{
    font-size:56px;
  }

  .hero-image{
    position:relative;
    top:auto;
    right:auto;
    transform:none;
    margin-top:40px;
    max-width:100%;
  }
}
</style>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Shape Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Product Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}