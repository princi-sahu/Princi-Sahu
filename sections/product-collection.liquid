<div class="tisso-wild-section">

  {% if section.settings.heading != blank %}
    <h2 class="tisso-wild-title">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  <div class="tisso-wild-grid">

    {% for block in section.blocks %}
      <div class="tisso-wild-item" {{ block.shopify_attributes }}>

        {% if block.settings.image != blank %}
          {{
            block.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              alt: block.settings.product_title
          }}
        {% endif %}

        <button
          class="tisso-hotspot-pin"
          style="top:{{ block.settings.pin_top }}%; left:{{ block.settings.pin_left }}%;"
          data-title="{{ block.settings.product_title }}"
          data-price="{{ block.settings.product_price }}"
          data-desc="{{ block.settings.product_desc }}"
          data-img="{{ block.settings.image | image_url: width: 500 }}"
        >
          +
        </button>

      </div>
    {% endfor %}

  </div>
</div>

<!-- Modal -->

<div id="tissoQuickViewModal" class="tisso-modal">

  <div class="tisso-modal-overlay"></div>

  <div class="tisso-modal-content">

    <button class="tisso-modal-close">
      &times;
    </button>

    <div class="tisso-modal-body">

      <div class="tisso-modal-left">
        <img id="tissoModalImg" src="" alt="">
      </div>

      <div class="tisso-modal-right">

        <h3 id="tissoModalTitle"></h3>

        <div id="tissoModalPrice"></div>

        <p id="tissoModalDesc"></p>

        <button id="tissoAddToCartBtn">
          ADD TO CART →
        </button>

      </div>

    </div>

  </div>

</div>

<style>
.tisso-wild-section{
  max-width:1440px;
  margin:0 auto;
  padding:60px 40px;
}

.tisso-wild-title{
  font-size:32px;
  margin-bottom:24px;
}

.tisso-wild-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
}

.tisso-wild-item{
  position:relative;
  aspect-ratio:1;
  overflow:hidden;
}

.tisso-wild-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

.tisso-hotspot-pin{
  position:absolute;
  width:30px;
  height:30px;
  border:none;
  border-radius:50%;
  background:#fff;
  cursor:pointer;
  transform:translate(-50%,-50%);
}

.tisso-modal{
  display:none;
  position:fixed;
  inset:0;
  z-index:999;
}

.tisso-modal.is-open{
  display:flex;
  align-items:center;
  justify-content:center;
}

.tisso-modal-overlay{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.4);
}

.tisso-modal-content{
  position:relative;
  background:#fff;
  width:600px;
  max-width:90%;
  padding:30px;
  z-index:2;
}

.tisso-modal-close{
  position:absolute;
  top:10px;
  right:15px;
  border:none;
  background:none;
  font-size:30px;
  cursor:pointer;
}

.tisso-modal-body{
  display:flex;
  gap:20px;
}

.tisso-modal-left,
.tisso-modal-right{
  flex:1;
}

.tisso-modal-left img{
  width:100%;
}

#tissoAddToCartBtn{
  width:100%;
  background:#000;
  color:#fff;
  border:none;
  padding:14px;
  margin-top:20px;
  cursor:pointer;
}

@media(max-width:768px){

  .tisso-wild-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .tisso-modal-body{
    flex-direction:column;
  }

}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const modal = document.getElementById("tissoQuickViewModal");

  const modalImg = document.getElementById("tissoModalImg");
  const modalTitle = document.getElementById("tissoModalTitle");
  const modalPrice = document.getElementById("tissoModalPrice");
  const modalDesc = document.getElementById("tissoModalDesc");

  document.querySelectorAll(".tisso-hotspot-pin").forEach(pin => {

    pin.addEventListener("click", () => {

      modalImg.src = pin.dataset.img;
      modalTitle.textContent = pin.dataset.title;
      modalPrice.textContent = pin.dataset.price;
      modalDesc.textContent = pin.dataset.desc;

      modal.classList.add("is-open");
    });

  });

  document.querySelector(".tisso-modal-close").addEventListener("click", () => {
    modal.classList.remove("is-open");
  });

  document.querySelector(".tisso-modal-overlay").addEventListener("click", () => {
    modal.classList.remove("is-open");
  });

});
</script>

{% schema %}
{
  "name": "Tisso Wild Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vision in the wild"
    }
  ],
  "blocks": [
    {
      "type": "image_item",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "product_price",
          "label": "Price"
        },
        {
          "type": "textarea",
          "id": "product_desc",
          "label": "Description"
        },
        {
          "type": "range",
          "id": "pin_top",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "label": "Pin Top"
        },
        {
          "type": "range",
          "id": "pin_left",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "label": "Pin Left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tisso Wild Grid"
    }
  ]
}
{% endschema %}