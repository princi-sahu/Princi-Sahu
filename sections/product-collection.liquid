<div class="tisso-wild-grid-wrapper">
  <div class="page-width">
    <div class="tisso-wild-grid">
  {% for block in section.blocks %}

    {% assign product = block.settings.product %}

    {% if product != blank %}
      <div class="tisso-wild-item" {{ block.shopify_attributes }}>

        {% if product.featured_image %}
          {{
            product.featured_image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              alt: product.title
          }}
        {% endif %}

        <button
          type="button"
          class="tisso-hotspot-pin"
          style="top:{{ block.settings.pin_top }}%; left:{{ block.settings.pin_left }}%;"
          data-title="{{ product.title }}"
          data-price="{{ product.price | money }}"
          data-desc="{{ product.description | strip_html | truncate: 120 }}"
          data-img="{{ product.featured_image | image_url: width: 500 }}"
        >
          +
        </button>

      </div>
    {% endif %}

  {% endfor %}
</div>
</div>
</div>
<!-- Modal -->

<div id="tissoQuickViewModal" class="tisso-modal">

  <div class="tisso-modal-overlay"></div>

  <div class="tisso-modal-content">

    <button class="tisso-modal-close">&times;</button>

    <div class="tisso-modal-body">

      <div class="tisso-modal-left">
        <img id="tissoModalImg" src="" alt="">
      </div>

      <div class="tisso-modal-right">

        <h3 id="tissoModalTitle"></h3>

        <div id="tissoModalPrice" class="tisso-modal-price"></div>

        <p id="tissoModalDesc" class="tisso-modal-desc"></p>

        <div class="tisso-option-group">
          <label>Color</label>

          <div class="tisso-color-options">
            <button class="active">White</button>
            <button>Black</button>
          </div>
        </div>

        <div class="tisso-option-group">
          <label>Size</label>

          <select class="tisso-size-select">
            <option>Choose your size</option>
            <option>S</option>
            <option>M</option>
            <option>L</option>
            <option>XL</option>
          </select>
        </div>

        <button id="tissoAddToCartBtn" class="tisso-add-cart">
          <span>ADD TO CART</span>
          <span>→</span>
        </button>

      </div>

    </div>

  </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const modal = document.getElementById("tissoQuickViewModal");

  const modalImg = document.getElementById("tissoModalImg");
  const modalTitle = document.getElementById("tissoModalTitle");
  const modalPrice = document.getElementById("tissoModalPrice");
  const modalDesc = document.getElementById("tissoModalDesc");

  document.querySelectorAll(".tisso-hotspot-pin").forEach(pin => {

    pin.addEventListener("click", () => {

      modalImg.src = pin.dataset.img;
      modalTitle.textContent = pin.dataset.title;
      modalPrice.textContent = pin.dataset.price;
      modalDesc.textContent = pin.dataset.desc;

      modal.classList.add("is-open");
    });

  });

  document.querySelector(".tisso-modal-close").addEventListener("click", () => {
    modal.classList.remove("is-open");
  });

  document.querySelector(".tisso-modal-overlay").addEventListener("click", () => {
    modal.classList.remove("is-open");
  });

});
</script>

{% schema %}
{
  "name": "Tisso Wild Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vision in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Product Item",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "range",
          "id": "pin_top",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "label": "Pin Top"
        },
        {
          "type": "range",
          "id": "pin_left",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "label": "Pin Left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tisso Wild Grid"
    }
  ]
}
{% endschema %}
<style>
.tisso-modal{
  position:fixed;
  inset:0;
  display:none;
  align-items:center;
  justify-content:center;
  z-index:999;
}

.tisso-modal.is-open{
  display:flex;
}

.tisso-modal-overlay{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.4);
}

.tisso-modal-content{
  position:relative;
  background:#F5F5F5;
  width:100%;
  max-width:900px;
  padding:40px;
  z-index:2;
}

.tisso-modal-close{
  position:absolute;
  top:20px;
  right:20px;
  border:none;
  background:none;
  font-size:40px;
  cursor:pointer;
}

.tisso-modal-body{
  display:flex;
  gap:40px;
}

.tisso-modal-left{
  width:45%;
}

.tisso-modal-left img{
  width:100%;
  display:block;
}

.tisso-modal-right{
  width:55%;
}

.tisso-modal-right h3{
  font-size:42px;
  font-weight:400;
  margin:0 0 20px;
}

.tisso-modal-price{
  font-size:48px;
  margin-bottom:20px;
}

.tisso-modal-desc{
  font-size:20px;
  line-height:1.5;
  margin-bottom:30px;
}

.tisso-option-group{
  margin-bottom:25px;
}

.tisso-option-group label{
  display:block;
  margin-bottom:10px;
  font-size:20px;
}

.tisso-color-options{
  display:flex;
}

.tisso-color-options button{
  flex:1;
  height:60px;
  border:1px solid #000;
  background:#fff;
  font-size:22px;
  cursor:pointer;
}

.tisso-color-options button.active{
  border-width:3px;
}

.tisso-size-select{
  width:100%;
  height:60px;
  padding:0 20px;
  font-size:22px;
  border:1px solid #000;
  background:#fff;
}

.tisso-add-cart{
  width:100%;
  height:70px;
  margin-top:40px;
  background:#000;
  color:#fff;
  border:none;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:30px;
  font-size:22px;
  cursor:pointer;
}

@media(max-width:768px){

  .tisso-modal-content{
    padding:20px;
    max-width:95%;
  }

  .tisso-modal-body{
    flex-direction:column;
  }

  .tisso-modal-left,
  .tisso-modal-right{
    width:100%;
  }

  .tisso-modal-right h3{
    font-size:28px;
  }

  .tisso-modal-price{
    font-size:32px;
  }

  .tisso-modal-desc{
    font-size:16px;
  }
}
</style>